# --- API Configuration ---
# Internal environment name (development, production)
NODE_ENV=development

# Server port
PORT=3001

# Database connection URL (SQLite path)
DATABASE_URL=./data/flashcards.db

# JWT signing secret (change this in production!)
JWT_SECRET=dev-secret-change-in-production

# CORS: Allowed client domain
CLIENT_ORIGIN=http://localhost:5173

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# --- Web (Frontend) Configuration ---
# API base URL for the frontend
VITE_API_URL=http://localhost:3001
