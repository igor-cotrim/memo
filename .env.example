# --- API Configuration ---
# Internal environment name (development, production)
NODE_ENV=development

# Server port
PORT=3333

# Database connection URL (PostgreSQL — Supabase connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase (backend — service role key is secret, never expose to client)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SECRET_KEY=eyJ...

# CORS: Allowed client domain
CLIENT_ORIGIN=http://localhost:5173

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# --- Web (Frontend) Configuration ---
# API base URL for the frontend
VITE_API_URL=http://localhost:3333

# Supabase (frontend — anon key is safe to expose)
VITE_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJ...
