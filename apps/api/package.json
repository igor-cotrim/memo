{
  "name": "@flashcard-app/api",
  "version": "1.0.0",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "dotenv -e ../../.env -- node dist/server.js",
    "start:prod": "node dist/server.js",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:watch": "dotenv -e ../../.env -- vitest",
    "test:coverage": "dotenv -e ../../.env -- vitest run --coverage",
    "test:unit": "dotenv -e ../../.env -- vitest run tests/unit",
    "test:integration": "dotenv -e ../../.env -- vitest run tests/integration",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@flashcard-app/shared-types": "workspace:*",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.8",
    "ts-fsrs": "^5.3.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
